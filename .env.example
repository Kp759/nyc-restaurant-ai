# ---------------------------------------------------------------------------
# BiteNYC environment variables
# Copy to .env (and apps/*/.env.local as needed) and fill in real values.
# ---------------------------------------------------------------------------

# --- Supabase ---------------------------------------------------------------
# Project URL, e.g. https://xxxxxxxx.supabase.co
SUPABASE_URL=
# Public anon key (safe for client / admin browser usage with RLS)
SUPABASE_ANON_KEY=
# Service role key (server-side ONLY: API + data jobs). Never ship to client.
SUPABASE_SERVICE_ROLE_KEY=
# Direct Postgres connection string (used by data jobs / migrations runner)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres

# --- OpenAI -----------------------------------------------------------------
OPENAI_API_KEY=
# Embedding + chat models (defaults match the BiteNYC schema vector(1536))
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# --- API server -------------------------------------------------------------
API_PORT=4000
API_HOST=0.0.0.0
# Comma separated list of allowed CORS origins
API_CORS_ORIGINS=http://localhost:3000
# Public base URL the importer uses to build proxied photo URLs (no trailing slash).
# Use your machine's LAN IP for a physical iPhone, e.g. http://192.168.1.20:4000
API_PUBLIC_URL=http://localhost:4000

# --- Admin (Next.js) --------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# --- Data jobs (optional until you run importers) ---------------------------
# Google Maps Platform key with the "Places API (New)" enabled + billing on.
# Used by the importer AND the API photo proxy (server-side only, never shipped).
GOOGLE_PLACES_API_KEY=
YELP_API_KEY=
# NYC DOHMH inspection results CSV/JSON endpoint (Socrata). Default is the
# public NYC Open Data resource id for restaurant inspection results.
NYC_DOHMH_SODA_URL=https://data.cityofnewyork.us/resource/43nn-pn8j.json
NYC_OPEN_DATA_APP_TOKEN=
